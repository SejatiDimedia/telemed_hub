# =============================================================================
# TeleMedHub — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository.
# =============================================================================

# Application
APP_ENV=development
APP_NAME=telemedhub
HTTP_PORT=8080
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgres://telemedhub:telemedhub_secret@postgres:5432/telemedhub?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=telemedhub

# JWT (Sprint 1 — leave defaults for now)
JWT_SECRET=change-me-to-a-32-byte-base64-encoded-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# LLM / AI (Sprint 11)
LLM_API_URL=https://api.example.com/v1/chat/completions
LLM_API_KEY=change-me

# SMTP / Notification (Sprint 10)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# Graceful shutdown
SHUTDOWN_TIMEOUT_SECONDS=15

# Appointment Configs
APPOINTMENT_CANCEL_CUTOFF_MINUTES=60
